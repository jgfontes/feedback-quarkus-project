									"});",
									"",
									"pm.test('Response é um array', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json).to.be.an('array');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/feedback",
							"host": ["{{base_url}}"],
							"path": ["feedback"]
						}
					}
				},
				{
					"name": "Buscar Feedback por ID",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200 OK', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response contém o feedback', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json.id).to.eql(pm.collectionVariables.get('feedback_id'));",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/feedback/{{feedback_id}}",
							"host": ["{{base_url}}"],
							"path": ["feedback", "{{feedback_id}}"]
						}
					}
				}
			]
		},
