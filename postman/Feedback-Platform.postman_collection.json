									"pm.test('Status 201 Created', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test('Urgência HIGH para nota < 6', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json.urgency).to.eql('HIGH');",
									"    pm.expect(json.grade).to.be.below(6);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
