meta {
  name: Create Feedback
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/feedback
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "id": 1,
    "description": "Aula excelente",
    "grade": 10
  }
}

vars:pre-request {
  baseUrl: http://localhost:8080
}
